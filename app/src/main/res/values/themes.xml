<resources>
    <!--
      Compose owns all UI styling (see presentation/theme/). This theme exists only
      because the manifest requires android:theme on the application/activity, and it
      governs the window for the brief moment before the first composition: no
      ActionBar, and an obsidian background so that frame does not flash white.
      Do not add colors here - AegisTheme is the source of truth.
    -->
    <style name="Theme.Aegis" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#FF101418</item>
    </style>
</resources>
